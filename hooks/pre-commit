#!/bin/sh
# Local quality gate — same checks AGENTS.md requires before finishing work.
set -e

# Integration guard: only the project session (which sets
# HORIZON_INTEGRATION=1) commits on main. Domain/task sessions and
# workers commit on their own branches and hand them to the review
# queue (AGENTS.md "Branch and Integration Flow").
branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ] && [ "${HORIZON_INTEGRATION:-0}" != "1" ]; then
  echo "pre-commit: refusing to commit on main without HORIZON_INTEGRATION=1" >&2
  echo "pre-commit: work on a branch and hand it to the review queue instead" >&2
  exit 1
fi

echo "pre-commit: cargo fmt --check"
cargo fmt --all -- --check

echo "pre-commit: cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

echo "pre-commit: cargo nextest run --workspace"
cargo nextest run --workspace

# The GPUI shell is its own workspace (docs/gpui-migration-design.md),
# invisible to the root --workspace runs above — gate it separately.
# No nextest leg yet: the crate has no tests; add one when it does.
echo "pre-commit: shell-gpui gate (second workspace)"
(cd shell-gpui && cargo fmt --all -- --check && cargo clippy --all-targets -- -D warnings)

echo "pre-commit: ast-grep scan (over-tracking lint, docs/agent-ui-performance-design.md leg 2)"
if ! command -v ast-grep >/dev/null 2>&1; then
  echo "pre-commit: ast-grep is not installed — this gate step is enforced, not optional" >&2
  echo "pre-commit: install ast-grep: npm install -g @ast-grep/cli (or: cargo install ast-grep --locked)" >&2
  exit 1
fi
ast-grep scan --error -r .config/ast-grep/overtracking.yml src crates
