#!/bin/sh
# Local quality gate — same checks AGENTS.md requires before finishing work.
set -e

echo "pre-commit: cargo fmt --check"
cargo fmt --all -- --check

echo "pre-commit: cargo clippy --workspace --all-targets --locked -- -D warnings"
cargo clippy --workspace --all-targets --locked -- -D warnings

echo "pre-commit: cargo nextest run --workspace --locked"
cargo nextest run --workspace --locked
