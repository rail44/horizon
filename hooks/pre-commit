#!/bin/sh
# Local quality gate — same checks AGENTS.md requires before finishing work.
set -e

# Hermetic gate: never let a personal config leak into tests — assertions
# about built-in defaults must hold on every machine.
export HORIZON_CONFIG=/nonexistent/horizon-pre-commit-hermetic.toml

echo "pre-commit: cargo fmt --check"
cargo fmt --all -- --check

echo "pre-commit: cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

echo "pre-commit: cargo test --workspace"
cargo test --workspace
